# Auction Platform - React Frontend Configuration

# API Gateway Base URL
# Used for all API requests (user credentials, auction data, bidding, leaderboard, etc.)
# Make sure this matches your gateway service port and host
REACT_APP_API_URL=http://localhost:8080/api

# JWT Token Configuration
# Key used to store authentication token in localStorage
REACT_APP_TOKEN_STORAGE_KEY=auction_auth_token

# Application Configuration
# Environment: development, staging, production
REACT_APP_ENV=development

# Debug Mode
# Set to 'true' to enable console logging of API calls and state changes
REACT_APP_DEBUG=false

# API Timeout (milliseconds)
# Maximum time to wait for API responses before timing out
REACT_APP_API_TIMEOUT=30000

# Session Configuration
# Auto-logout user if inactive for this many minutes
REACT_APP_SESSION_TIMEOUT_MINUTES=30

# Feature Flags
# Enable/disable specific features
REACT_APP_ENABLE_AUCTION_CREATION=true
REACT_APP_ENABLE_BIDDING=true
REACT_APP_ENABLE_LEADERBOARD=true
REACT_APP_ENABLE_ANALYTICS=false
