                  "});",
                  "",
                  "let data = {};",
                  "try { data = pm.response.json(); } catch (e) {}",
                  "",
                  "pm.test(\"Response contains order info\", function () {",
                  "    pm.expect(data.orderId || data.order_id).to.exist;",
                  "});",
                  "",
                  "pm.test(\"Response contains totals\", function () {",
                  "    pm.expect(data.itemPrice ?? data.item_price).to.exist;",
                  "    pm.expect(data.shippingCost ?? data.shipping_cost).to.exist;",
                  "    pm.expect(data.total).to.exist;",
                  "});",
                  "",
                  "pm.test(\"Response contains shipping address\", function () {",
                  "    pm.expect(data.shippingAddress || data.address).to.exist;",
                  "});"
                ]
              }
            }
          ]
