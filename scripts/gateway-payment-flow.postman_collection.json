                  "const auctionId = data.auctionId || data.id || data.auction_id;",
                  "pm.test(\"Auction ID returned\", function () {",
                  "    pm.expect(auctionId, \"Missing auctionId in response\").to.exist;",
                  "});",
                  "if (auctionId) pm.collectionVariables.set(\"auctionId\", String(auctionId));"
