      "name": "Main End-to-End Flow",
      "item": [
        {
          "name": "1 - Create Buyer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/signup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "signup"
              ]
            },
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{buyerUsername}}\",\n  \"password\": \"{{buyerPassword}}\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john@email.com\",\n  \"role\": \"BUYER\",\n  \"shippingAddress\": {\n    \"streetNumber\": \"10\",\n    \"streetName\": \"King St\",\n    \"city\": \"Toronto\",\n    \"country\": \"Canada\",\n    \"postalCode\": \"M1M1M1\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is success\", function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "let data = {};",
                  "try { data = pm.response.json(); } catch (e) {}",
                  "",
                  "const userId = data.userId || data.id || data.user_id;",
                  "if (userId) {",
                  "    if (pm.info.requestName.toLowerCase().includes(\"buyer\")) {",
                  "        pm.collectionVariables.set(\"buyerUserId\", String(userId));",
                  "    } else {",
                  "        pm.collectionVariables.set(\"sellerUserId\", String(userId));",
                  "    }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "2 - Login Buyer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{buyerUsername}}\",\n  \"password\": \"{{buyerPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Login succeeded\", function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "let data = {};",
                  "try { data = pm.response.json(); } catch (e) {}",
                  "",
                  "const token = data.token || data.jwt || data.accessToken || data.access_token;",
                  "const userId = data.userId || data.id || data.user_id;",
                  "",
                  "pm.test(\"Token returned\", function () {",
                  "    pm.expect(token, \"Missing token in response\").to.exist;",
                  "});",
                  "",
                  "if (pm.info.requestName.toLowerCase().includes(\"buyer\")) {",
                  "    if (token) pm.collectionVariables.set(\"buyerToken\", String(token));",
                  "    if (userId) pm.collectionVariables.set(\"buyerUserId\", String(userId));",
                  "} else {",
                  "    if (token) pm.collectionVariables.set(\"sellerToken\", String(token));",
                  "    if (userId) pm.collectionVariables.set(\"sellerUserId\", String(userId));",
                  "}"
                ]
              }
            }
          ]
        },
