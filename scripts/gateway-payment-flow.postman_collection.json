                "{{auctionId}}",
                "close"
              ]
            },
            "description": ""
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Auction closed\", function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 202]);",
                  "});",
                  "",
                  "let data = {};",
                  "try { data = pm.response.json(); } catch (e) {}",
                  "",
                  "const status = data.status || data.auctionStatus;",
                  "const winnerId = data.winnerId || data.winnerUserId || (data.winner && (data.winner.userId || data.winner.id));",
                  "",
                  "if (status) {",
                  "    pm.test(\"Auction status is CLOSED\", function () {",
                  "        pm.expect(String(status).toUpperCase()).to.eql(\"CLOSED\");",
                  "    });",
                  "}",
                  "if (winnerId) {",
                  "    pm.test(\"Winner is the buyer\", function () {",
                  "        pm.expect(String(winnerId)).to.eql(pm.collectionVariables.get(\"buyerUserId\"));",
                  "    });",
                  "}"
                ]
              }
            }
          ]
        },
